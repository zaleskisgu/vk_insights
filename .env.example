APP_NAME=Laravel
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost

# VK API: см. config/vk.php
VK_USE_MOCK=true
VK_SERVICE_TOKEN=201cdc74201cdc74201cdc748b235c4fbf2201c201cdc7449f726287ec0510e8a641dcb
VK_API_VERSION=5.199
# Кэш wall.get + groups.getById (сек)
VK_CACHE_TTL=1200
# Максимальная ширина периода from..to в днях.
VK_PERIOD_MAX_DAYS=3650
# Часовой пояс для дат постов и времени генерации отчёта.
VK_TIMEZONE=Europe/Moscow
# Лимит страниц wall.get на один отчёт (max_pages * page_size = лимит постов).
# VK_WALL_MAX_PAGES=50
# Размер страницы wall.get (VK ограничивает 100).
# VK_WALL_PAGE_SIZE=100
# Для tests/Integration/VkHttpClientIntegrationTest (публичное сообщество по умолчанию 22822305)
# VK_INTEGRATION_TEST_GROUP_ID=22822305

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=sqlite
# DB_HOST=127.0.0.1
# DB_PORT=3306
# DB_DATABASE=laravel
# DB_USERNAME=root
# DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"
